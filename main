#!/bin/bash
#PBS -l nodes=1:ppn=1,vmem=8g,walltime=1:00:00
#PBS -N app-tract-transform
#PBS -V

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APPLY_SCRIPT="${SCRIPT_DIR}/applyTransformations2tract.sh"

expand_path() {
    local p="$1"
    [[ -z "$p" || "$p" == "null" ]] && { echo "$p"; return; }

    p="${p/#\~/$HOME}"
    realpath "$p"
}

echo "[INFO] Loading parameters from config.json"

tractogram=$(expand_path "$(jq -r '.input_tract' config.json)")
tcks=$(expand_path "$(jq -r '.tcks' config.json)")

# --- validate single-tract vs folder input ---
if [[ "$tractogram" != "null" && -n "$tractogram" && "$tcks" != "null" && -n "$tcks" ]]; then
    echo "Error: provide either 'input_tract' or 'tcks', not both." >&2
    exit 1
fi

if [[ ( "$tractogram" == "null" || -z "$tractogram" ) && ( "$tcks" == "null" || -z "$tcks" ) ]]; then
    echo "Error: one of 'input_tract' or 'tcks' must be provided." >&2
    exit 1
fi

if [[ "$tractogram" != "null" && -n "$tractogram" && ! -f "$tractogram" ]]; then
    echo "Error: input_tract does not exist: $tractogram" >&2
    exit 1
fi

resolved_tcks_dir="null"

if [[ "$tcks" != "null" && -n "$tcks" ]]; then

    if [[ -d "$tcks" ]]; then
        :
    else
        echo "[WARN] tcks is not a directory: $tcks"
        echo "[WARN] checking parent folder instead..."
        tcks="$(dirname "$tcks")"
    fi

    # prefer nested tcks folder if it exists
    if [[ -d "$tcks/tcks" ]]; then
        tcks="$tcks/tcks"
    fi

    # check that we actually have tractograms
    shopt -s nullglob
    tck_files=("$tcks"/*.tck)
    shopt -u nullglob

    if [[ ${#tck_files[@]} -eq 0 ]]; then
        echo "Error: no .tck files found in directory: $tcks" >&2
        exit 1
    fi

    resolved_tcks_dir="$tcks"
fi

# Optional moving-space anatomical fields
t1w=$(expand_path "$(jq -r '.t1' config.json)")
t2w=$(expand_path "$(jq -r '.t2' config.json)")
fa=$(expand_path "$(jq -r '.fa' config.json)")

# Assign first available moving image
if [ -n "$t1w" ] && [ "$t1w" != "null" ]; then
    input_moving="$t1w"
elif [ -n "$t2w" ] && [ "$t2w" != "null" ]; then
    input_moving="$t2w"
elif [ -n "$fa" ] && [ "$fa" != "null" ]; then
    input_moving="$fa"
else
    echo "Error: No valid moving image found in config.json" >&2
    exit 1
fi

# Optional fixed/reference anatomical fields
t1w_fixed=$(expand_path "$(jq -r '.t1_fixed' config.json)")
t2w_fixed=$(expand_path "$(jq -r '.t2_fixed' config.json)")
fa_fixed=$(expand_path "$(jq -r '.fa_fixed' config.json)")

# Assign first available fixed image
if [ -n "$t1w_fixed" ] && [ "$t1w_fixed" != "null" ]; then
    input_fixed="$t1w_fixed"
elif [ -n "$t2w_fixed" ] && [ "$t2w_fixed" != "null" ]; then
    input_fixed="$t2w_fixed"
elif [ -n "$fa_fixed" ] && [ "$fa_fixed" != "null" ]; then
    input_fixed="$fa_fixed"
else
    echo "Error: No valid fixed/reference image found in config.json" >&2
    exit 1
fi

affine=$(expand_path "$(jq -r '.affine' config.json)")
warp=$(expand_path "$(jq -r '.warp' config.json)")
inverse_warp=$(expand_path "$(jq -r '."inverse-warp"' config.json)")

forward_operation=$(jq -r '.forward_operation // false' config.json)
reverse_operation=$(jq -r '.reverse_operation // false' config.json)
verbose=$(jq -r '.verbose // false' config.json)
affine_only=$(jq -r '.affine_only // false' config.json)

if [ "$affine_only" != "true" ]; then
    if [ "$reverse_operation" = "true" ] && { [ -z "$warp" ] || [ "$warp" = "null" ]; }; then
        echo "Error: reverse_operation=true requires a valid forward warp" >&2
        exit 1
    fi

    if [ "$forward_operation" = "true" ] && [ "$reverse_operation" != "true" ] && { [ -z "$inverse_warp" ] || [ "$inverse_warp" = "null" ]; }; then
        echo "Error: forward_operation=true requires a valid inverse-warp unless reverse_operation=true" >&2
        exit 1
    fi
fi

# Select warp direction
selected_warp="None"

if [ "$affine_only" = "true" ]; then
    selected_warp="None"
elif [ "$reverse_operation" = "true" ]; then
    if [ -n "$warp" ] && [ "$warp" != "null" ]; then
        selected_warp="$warp"
    fi
elif [ "$forward_operation" = "true" ]; then
    if [ -n "$inverse_warp" ] && [ "$inverse_warp" != "null" ]; then
        selected_warp="$inverse_warp"
    fi
else
    if [ -n "$warp" ] && [ "$warp" != "null" ]; then
        selected_warp="$warp"
    fi
fi

# Brainlife-style output directory
outputdir="${SCRIPT_DIR}/transformed"
mkdir -p "$outputdir"

echo "[INFO] moving image      : $input_moving"
echo "[INFO] reference image   : $input_fixed"
echo "[INFO] affine            : $affine"
echo "[INFO] warp              : $warp"
echo "[INFO] inverse warp      : $inverse_warp"
echo "[INFO] affine_only       : $affine_only"
echo "[INFO] forward_operation            : $forward_operation"
echo "[INFO] reverse_operation : $reverse_operation"
echo "[INFO] selected warp     : $selected_warp"
echo "[INFO] output directory  : $outputdir"

run_one_tract() {
    local in_tract="$1"
    local out_tract="$2"

    echo "[INFO] tractogram        : $in_tract"
    echo "[INFO] output            : $out_tract"

    cmd=(bash "$APPLY_SCRIPT"
        --in "$in_tract"
        --reference "$input_fixed"
        --moving "$input_moving"
        --affine "$affine"
        --warp "$selected_warp"
        --out "$out_tract"
        --convert-affine
    )

    if [ "$forward_operation" = "true" ]; then
        cmd+=(--invert)
    fi

    if [ "$reverse_operation" = "true" ]; then
        cmd+=(--reverse-operation)
    fi

    if [ "$verbose" = "true" ]; then
        cmd+=(-v)
    fi

    echo "[INFO] Running inside Singularity:"
    printf ' %q' "${cmd[@]}"
    echo

    echo "[INFO] Running container command:"
    printf ' %q' micromamba run -n tract_align "${cmd[@]}"
    echo

    singularity exec -e \
        docker://gamorosino/tract_align:latest \
        micromamba run -n tract_align "${cmd[@]}"
}

# --- run single tract or loop over folder ---
if [[ "$tractogram" != "null" && -n "$tractogram" ]]; then
    output_track="${outputdir}/$(basename "${tractogram}")"
    run_one_tract "$tractogram" "$output_track"
else
    shopt -s nullglob
    tck_files=("$resolved_tcks_dir"/*.tck)
    shopt -u nullglob

    if [ ${#tck_files[@]} -eq 0 ]; then
        echo "Error: no .tck files found in directory: $resolved_tcks_dir" >&2
        exit 1
    fi

    echo "[INFO] Found ${#tck_files[@]} .tck files in $resolved_tcks_dir"

    for tract_file in "${tck_files[@]}"; do
        output_track="${outputdir}/$(basename "${tract_file}")"
        run_one_tract "$tract_file" "$output_track"
    done
fi

echo "[INFO] Done"
