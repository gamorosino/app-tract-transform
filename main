#!/bin/bash
#PBS -l nodes=1:ppn=1,vmem=8g,walltime=1:00:00
#PBS -N app-tract-transform
#PBS -V

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APPLY_SCRIPT=${SCRIPT_DIR}"/applyTransformations2tract.sh"

expand_path() {
    local p="$1"
    [[ -z "$p" || "$p" == "null" ]] && { echo "$p"; return; }

    p="${p/#\~/$HOME}"

    realpath "$p"
}

echo "[INFO] Loading parameters from config.json"

tractogram=$(expand_path "$(jq -r '.input_tract' config.json)")

# Optional moving-space anatomical fields
t1w=$(expand_path "$(jq -r '.t1' config.json)")
t2w=$(expand_path "$(jq -r '.t2' config.json)")
fa=$(expand_path "$(jq -r '.fa' config.json)")

# Assign first available moving image
if [ -n "$t1w" ] && [ "$t1w" != "null" ]; then
    input_moving="$t1w"
elif [ -n "$t2w" ] && [ "$t2w" != "null" ]; then
    input_moving="$t2w"
elif [ -n "$fa" ] && [ "$fa" != "null" ]; then
    input_moving="$fa"
else
    echo "Error: No valid moving image found in config.json" >&2
    exit 1
fi

# Optional fixed/reference anatomical fields
t1w_fixed=$(expand_path "$(jq -r '.t1_fixed' config.json)")
t2w_fixed=$(expand_path "$(jq -r '.t2_fixed' config.json)")
fa_fixed=$(expand_path "$(jq -r '.fa_fixed' config.json)")

# Assign first available fixed image
if [ -n "$t1w_fixed" ] && [ "$t1w_fixed" != "null" ]; then
    input_fixed="$t1w_fixed"
elif [ -n "$t2w_fixed" ] && [ "$t2w_fixed" != "null" ]; then
    input_fixed="$t2w_fixed"
elif [ -n "$fa_fixed" ] && [ "$fa_fixed" != "null" ]; then
    input_fixed="$fa_fixed"
else
    echo "Error: No valid fixed/reference image found in config.json" >&2
    exit 1
fi

affine=$(expand_path "$(jq -r '.affine' config.json)")
warp=$(expand_path "$(jq -r '.warp' config.json)")
inverse_warp=$(expand_path "$(jq -r '."inverse-warp"' config.json)")

invert=$(jq -r '.invert // false' config.json)
reverse_operation=$(jq -r '.reverse_operation // false' config.json)
verbose=$(jq -r '.verbose // false' config.json)

if [ "$reverse_operation" = "true" ] && { [ -z "$warp" ] || [ "$warp" = "null" ]; }; then
    echo "Error: reverse_operation=true requires a valid forward warp" >&2
    exit 1
fi

if [ "$invert" = "true" ] && [ "$reverse_operation" != "true" ] && { [ -z "$inverse_warp" ] || [ "$inverse_warp" = "null" ]; }; then
    echo "Error: invert=true requires a valid inverse-warp unless reverse_operation=true" >&2
    exit 1
fi

# Select warp direction
selected_warp="None"

if [ "$reverse_operation" = "true" ]; then
    if [ -n "$warp" ] && [ "$warp" != "null" ]; then
        selected_warp="$warp"
    fi
elif [ "$invert" = "true" ]; then
    if [ -n "$inverse_warp" ] && [ "$inverse_warp" != "null" ]; then
        selected_warp="$inverse_warp"
    fi
else
    if [ -n "$warp" ] && [ "$warp" != "null" ]; then
        selected_warp="$warp"
    fi
fi

# Brainlife-style output directory
outputdir="${SCRIPT_DIR}/transformed"
mkdir -p "$outputdir"

output_track="${outputdir}/$(basename "${tractogram}")"

echo "[INFO] tractogram        : $tractogram"
echo "[INFO] moving image      : $input_moving"
echo "[INFO] reference image   : $input_fixed"
echo "[INFO] affine            : $affine"
echo "[INFO] warp              : $warp"
echo "[INFO] inverse warp      : $inverse_warp"
echo "[INFO] invert            : $invert"
echo "[INFO] reverse_operation : $reverse_operation"
echo "[INFO] selected warp     : $selected_warp"
echo "[INFO] output            : $output_track"

cmd=(bash "$APPLY_SCRIPT"
    --in "$tractogram"
    --reference "$input_fixed"
    --moving "$input_moving"
    --affine "$affine"
    --warp "$selected_warp"
    --out "$output_track"
    --convert-affine
)

if [ "$invert" = "true" ]; then
    cmd+=(--invert)
fi

if [ "$reverse_operation" = "true" ]; then
    cmd+=(--reverse-operation)
fi

if [ "$verbose" = "true" ]; then
    cmd+=(-v)
fi

echo "[INFO] Running inside Singularity:"
printf ' %q' "${cmd[@]}"
echo

inner_cmd="micromamba run -n tract_align $(printf '%q ' "${cmd[@]}")"

echo "[INFO] Inner container command:"
echo "$inner_cmd"

singularity exec -e \
    docker://gamorosino/tract_align:latest \
    bash -lc "$inner_cmd"

echo "[INFO] Done"
